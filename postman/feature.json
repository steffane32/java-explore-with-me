{
  "info": {
    "name": "Explore With Me - Comments Feature",
    "description": "Тесты для проверки функциональности комментариев",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public: Комментарии",
      "item": [
        {
          "name": "Получение одобренных комментариев к событию",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ответ должен содержать код статуса 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Ответ должен быть массивом', function() {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "http://localhost:8080/events/1/comments",
              "host": ["http://localhost:8080"],
              "path": ["events", "1", "comments"]
            }
          }
        }
      ]
    },
    {
      "name": "Private: Комментарии",
      "item": [
        {
          "name": "Добавление комментария к событию",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ответ должен содержать код статуса 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Тело ответа должно содержать id', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('id');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "http://localhost:8080/users/1/comments?eventId=1",
              "host": ["http://localhost:8080"],
              "path": ["users", "1", "comments"],
              "query": [{"key": "eventId", "value": "1"}]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"text\": \"Отличное событие! Очень понравилось.\"}"
            }
          }
        },
        {
          "name": "Редактирование своего комментария",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ответ должен содержать код статуса 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Текст комментария должен обновиться', function() {",
                  "    pm.expect(pm.response.json().text).to.eql('Обновлённый текст комментария');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "http://localhost:8080/users/1/comments/1",
              "host": ["http://localhost:8080"],
              "path": ["users", "1", "comments", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"text\": \"Обновлённый текст комментария\"}"
            }
          }
        },
        {
          "name": "Удаление своего комментария",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ответ должен содержать код статуса 204', function() {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "http://localhost:8080/users/1/comments/1",
              "host": ["http://localhost:8080"],
              "path": ["users", "1", "comments", "1"]
            }
          }
        },
        {
          "name": "Получение комментариев текущего пользователя",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ответ должен содержать код статуса 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "http://localhost:8080/users/1/comments",
              "host": ["http://localhost:8080"],
              "path": ["users", "1", "comments"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin: Комментарии",
      "item": [
        {
          "name": "Получение комментариев на модерацию",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ответ должен содержать код статуса 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "http://localhost:8080/admin/comments",
              "host": ["http://localhost:8080"],
              "path": ["admin", "comments"]
            }
          }
        },
        {
          "name": "Одобрение комментария",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ответ должен содержать код статуса 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Статус комментария должен измениться на APPROVED', function() {",
                  "    pm.expect(pm.response.json().status).to.eql('APPROVED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "http://localhost:8080/admin/comments/1",
              "host": ["http://localhost:8080"],
              "path": ["admin", "comments", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"APPROVED\"}"
            }
          }
        },
        {
          "name": "Отклонение комментария",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ответ должен содержать код статуса 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Статус комментария должен измениться на REJECTED', function() {",
                  "    pm.expect(pm.response.json().status).to.eql('REJECTED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "http://localhost:8080/admin/comments/1",
              "host": ["http://localhost:8080"],
              "path": ["admin", "comments", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"REJECTED\"}"
            }
          }
        },
        {
          "name": "Удаление комментария администратором",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ответ должен содержать код статуса 204', function() {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "http://localhost:8080/admin/comments/1",
              "host": ["http://localhost:8080"],
              "path": ["admin", "comments", "1"]
            }
          }
        }
      ]
    }
  ]
}